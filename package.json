  },
  "keywords": [
    "solana",
    "defi",
    "ai-agent",
    "nft-minting",
    "liquidity-pool",
    "meteora",
    "dlmm",
    "multi-agent",
    "hermes-agent"
  ],
  "dependencies": {
    "@meteora-ag/dlmm": "^1.0.0",
    "@solana/web3.js": "^1.90.0",
    "@solana/spl-token": "^0.4.0",
    "bs58": "^6.0.0"
  },
  "license": "MIT"
}
