{
  "name": "solanaforge",
  "version": "1.0.0",
  "description": "Autonomous AI Agent Framework for Solana DeFi — NFT minting, LP management, on-chain intelligence, security audit",
  "main": "agents/lp/lp_bot.js",
  "scripts": {
    "screen": "node agents/lp/lp_bot.js screen",
    "deploy": "node agents/lp/lp_bot.js deploy",
    "status": "node agents/lp/lp_bot.js status",
