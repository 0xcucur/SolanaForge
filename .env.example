# SolanaForge Environment Variables
# Copy to .env and fill in your values

# Solana
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
WALLET_PATH=~/.hermes/wallets/wallets.json

# Agent Meridian (LP strategy research)
AGENT_MERIDIAN_KEY=YOUR_AGENT_MERIDIAN_KEY

# Birdeye (optional, for advanced token data)
BIRDEYE_API_KEY=YOUR_API_KEY

# EVM (optional, for custom RPC)
ETH_RPC=https://eth.llamarpc.com
BASE_RPC=https://base.llamarpc.com
